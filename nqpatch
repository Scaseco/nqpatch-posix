#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

case "${1:-}" in
  create) shift; exec "${SCRIPT_DIR}/nqpatch-create.sh" "$@" ;;
  apply)  shift; exec "${SCRIPT_DIR}/nqpatch-apply.sh" "$@" ;;
  merge)  shift; exec "${SCRIPT_DIR}/nqpatch-merge.sh" "$@" ;;
  track)  shift; exec "${SCRIPT_DIR}/nqpatch-track.sh" "$@" ;;
  *)      echo "Usage: $0 {create|apply|merge|track create} [args...]" >&2; exit 1 ;;
esac

